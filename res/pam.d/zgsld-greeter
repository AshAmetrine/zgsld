# Example PAM service for the zgsld greeter session on Linux.
#
# Install as /etc/pam.d/zgsld-greeter and set:
#   [greeter]
#   service_name = zgsld-greeter
#
# zgsld only opens a PAM session for the greeter user with this service,
# so only the session stack is inherited from the normal login policy.

session   include   login
